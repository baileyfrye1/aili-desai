---
import romanClayGreen from '../assets/roman-clay-green.webp'
import ContactForm from './ContactForm.astro';
---

<section id="contact" class="contact" style={{"--contact-bg": `url(${romanClayGreen.src})`}}>
    <div class="container">
        <h2 class="contact__title">Get in Touch</h2>
        <ContactForm />
    </div>
</section>

<style lang="scss">
    @use "../styles/mixins" as m;

    .contact {
        background-color: var(--clr-primary-200);
        padding: 3rem 0 6rem;
        position: relative;

        .container {
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            padding-inline: 0;
        }

        &__title {
            font-size: var(--font-700);
            font-family: "Inria Serif";
            position: relative;

            &::after {
                content: "";
                position: absolute;
                height: 2px;
                width: 6rem;
                left: 50%;
                bottom: 0;
                translate: -50%;
                display: block;
                background-color: var(--clr-neutral-200);
            }
        }
    }

    @include m.mq(small) {
        .contact {
            .container {
                padding-inline: 1.5rem;
            }
        }
    }
</style>
